    "/video/watch/{videoId}": {
      "get": {
        "tags": [
          "Videos"
        ],
        "description": "Video download route",
        "parameters": [
          {
            "name": "videoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the video to watch",
            "example": "1234567890"
          },
          {
            "name": "x-auth-token",
            "in": "header",
            "description": "Authorization token, required for not public videos",
            "required": false,
            "example": "Bearer <token>",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "range",
            "in": "header",
            "description": "Range of bytes to download, for partial video download",
            "required": false,
            "example": "bytes=0-100",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Video file download",
            "content": {
              "video/mp4": {
                "schema": {
                  "type": "file",
                  "format": "binary"
