                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Bad request"
                    }
                  },
                  "xml": {
                    "name": "main"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized, a valid token is required for this type of feed",
