  "version": "0.1.0",
  "description": "EzClips backend API server",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm run swagger && tsc",
    "start": "node dist/index.js",
    "swagger": "node ./swagger.mjs",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Trino11/ez-clips-server.git"
  },
  "author": "Trino11",
